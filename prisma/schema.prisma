generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  refreshToken      String? 
  createdAt DateTime @default(now())
  posts     Post[]   
}
model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  coverImage  String?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}
